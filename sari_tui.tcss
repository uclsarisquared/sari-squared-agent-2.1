#input_text {
    height: 4;
    scrollbar-size: 1 1;
}

#enter_button {
    height: 4;
}

LLMInput {
    dock: bottom;
}

UserPrompt {
    background: #1f1f1f;
    align-vertical: middle;
    padding-top: 1;
    color: white;
    align-horizontal: left;
}

#user_prompt {
    color: white;
    margin-right: 5;
    margin-left: 0;
    padding-left: 1;
}

#spinner_icon {
    opacity: 50%;
}

.spinner_done {
    opacity: 100%;
}

LLMToolCallDisplay {
    border: panel $secondary-muted;
    border-title-align: center;
    height: 3;
    align: center middle;
    margin-bottom: 1;
}

LLMThinkingSummary {
    margin: 0;
}

#user_llm_screen {
    scrollbar-size: 1 1;
}

#thinking_collapsible {
    background: $boost 75%;
    opacity: 50%;
}

#log_collapsible {
    background: $background;
    color: $background;
}

#raw_log {
    height: 10;
}

LLMResponse {
    align-horizontal: right;
}

#llm_resp_bullet {
    width: 2;
    color: white;
}

#llm_response_text {
    padding: 0;
    color: white;
}

#input_arrow {
    color: white;
    align: left top;
    width: 2;
    padding: 0;
}

#input_text {
    height: 2;
    background: $background;
    padding: 0;
    color: white;
    width: 90%;
    align: right middle;
}

LLMUserInput {
    border: hkey $foreground;
    padding: 0;
    height: 3;
}

#token_usage_label {
    text-align: right;
    margin-bottom: 1;
    opacity: 50%;
}

WelcomeHeader {
    height: 12;
    align: center top;
    border: round $primary;
    padding: 0;
    margin: 0;
}

#welcome_header {
    padding: 0 1 1 1;
    offset-y: -1;
    text-align: center;
}

.tool_success {
    color: $accent;
    border: panel $accent;
}

#debug_log {
    background: #000000;
}
